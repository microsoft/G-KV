{
    "zero_optimization": {
        "stage": 2,
        "offload_optimizer": {
            "device": "cpu",
            "pin_memory": true
        },
        "allgather_partitions": true,
        "allgather_bucket_size": 2e8,
        "overlap_comm": true,
        "reduce_scatter": true,
        "reduce_bucket_size": 2e8,
        "contiguous_gradients": true
    },
    "bf16": {
        "enabled": true
    },
    "gradient_clipping": 1.0,
    "steps_per_print": 100,
    "train_micro_batch_size_per_gpu":1,
    "gradient_accumulation_steps": 4,
    "tensor_parallel": {
        "autotp_size": 1
    }
}